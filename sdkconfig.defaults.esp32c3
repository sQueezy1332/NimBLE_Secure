CONFIG_BLINK_LED_STRIP=n
CONFIG_BT_NIMBLE_50_FEATURE_SUPPORT=y
CONFIG_BT_NIMBLE_LL_CFG_FEAT_LE_2M_PHY=n
CONFIG_BT_NIMBLE_EXT_ADV=y
CONFIG_BT_NIMBLE_SVC_GAP_DEVICE_NAME="esp32c3"
CONFIG_PARTITION_TABLE_CUSTOM_FILENAME="partition_4mb_ota.csv"
CONFIG_BLINK_LED_GPIO=y
CONFIG_BLINK_GPIO=13
CONFIG_ESPTOOLPY_FLASHFREQ="80m"
CONFIG_ESPTOOLPY_FLASHSIZE="4MB"
CONFIG_ESPTOOLPY_FLASHSIZE_4MB=y

CONFIG_LWIP_IP_FORWARD=y
CONFIG_LWIP_IPV4_NAPT=y
#CONFIG_LWIP_NUM_NETIF_CLIENT_DATA=y
